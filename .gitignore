# Binaries
/arbos
/forest
/bin/
*.exe

# Go build/test artifacts
*.test
*.out
/vendor/

# Local env / secrets (use doppler)
.env
.env.*

# Editor
.idea/
.vscode/

# Throwaway experiments / demo scratch
/scratch/
/ralph-primes/
/edit_demo.txt
/dog.png
/dog.svg
/ibm-canvas.html
/canvas/

# Files attached to a chat (the composer's paperclip spools them here)
.arbos/attachments/
.arbos/watch/
# Per-process forest lock (machine state, not portable; the agent key is)
.arbos/agent.lock
# Per-directory agent identity key (a secret) — never committed
.arbos/agent.key
# Project prompt overrides written at runtime — local, not portable
.arbos/prompts/
# Telegram bot registry — holds bot tokens, strictly per-directory, never committed
.arbos/messenger/
# Per-directory agent brain (sessions, mind, plans, callbacks) — never committed
.arbos/sessions.db
.arbos/sessions.db-wal
.arbos/sessions.db-shm

# Web UI build deps (dist/ is committed: go:embed needs it)
web/node_modules/
web/tsconfig.tsbuildinfo

# Node deps / build info anywhere
node_modules/
*.tsbuildinfo

# Cloudflare Pages / Wrangler (site/): local cache + account creds + secrets
.wrangler/
.dev.vars
.dev.vars.*
